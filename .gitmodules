[submodule ".registry"]
	path = .registry
	url = https://github.com/r-universe-org/cran-to-git
	branch = HEAD
[submodule "BayesianQDM"]
	path = BayesianQDM
	url = https://github.com/gosukehommaex/bayesianqdm
[submodule "FastSurvival"]
	path = FastSurvival
	url = https://github.com/gosukehommaex/fastsurvival
[submodule "RegionalConsistency"]
	path = RegionalConsistency
	url = https://github.com/gosukehommaex/regionalconsistency
[submodule "SingleArmMRCT"]
	path = SingleArmMRCT
	url = https://github.com/gosukehommaex/singlearmmrct
[submodule "bbssr"]
	path = bbssr
	url = https://github.com/gosukehommaex/bbssr
[submodule "simFastBOIN"]
	path = simFastBOIN
	url = https://github.com/gosukehommaex/simfastboin
[submodule "twoCoprimary"]
	path = twoCoprimary
	url = https://github.com/gosukehommaex/twocoprimary
